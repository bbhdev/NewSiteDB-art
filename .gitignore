/site/accounts/*
!/site/accounts/index.html
/site/cache/*
!/site/cache/index.html
/site/sessions/*
!/site/sessions/index.html
/media/*
!/media/index.html
.DS_Store
Thumbs.db

# Editor-authored data lives alongside .example.json seeds.
# The real .json files are user content (written by /dev/draw/save);
# they're ignored so pulls never collide with locally-saved drawings.
# On fresh clones the snippet/template falls back to the .example file.
/content/colors.json
/content/*/lines.json
/content/*/groups.json
/content/*/page.json
/content/*/*/lines.json
/content/*/*/groups.json
/content/*/*/instances.json
/content/_shared/classes.json
/content/_shared/masters.json
/content/_shared/palette.json
/content/_shared/font-bundle.json

# v0.8.34: snapshot library — local backups of /content, not source.
# Each subdir under /library/ is one named snapshot saved via the
# editor's Master library → snapshots dialog. Commit explicitly if
# you want a particular snapshot tracked.
/library/*
!/library/.gitkeep
