/site/accounts/*
!/site/accounts/index.html
/site/cache/*
!/site/cache/index.html
/site/sessions/*
!/site/sessions/index.html
/media/*
!/media/index.html
.DS_Store
Thumbs.db

# Editor-authored data lives alongside .example.json seeds.
# The real .json files are user content (written by /dev/draw/save);
# they're ignored so pulls never collide with locally-saved drawings.
# On fresh clones the snippet/template falls back to the .example file.
/content/colors.json
# Root-level page (the "home" page served from /content directly, no
# per-page subdir) — its config and per-class data sit one level
# shallower than other pages, so they need their own patterns.
/content/page.json
/content/*/instances.json
/content/*/lines.json
/content/*/groups.json
# Per-page (subdir'd) pages — config + per-class data nested one deeper.
/content/*/page.json
/content/*/*/lines.json
/content/*/*/groups.json
/content/*/*/instances.json
/content/_shared/classes.json
/content/_shared/masters.json
/content/_shared/palette.json
/content/_shared/font-bundle.json

# v0.8.34: snapshot library — local backups of /content, not source.
# Each subdir under /library/ is one named snapshot saved via the
# editor's Master library → snapshots dialog. Commit explicitly if
# you want a particular snapshot tracked.
/library/*
!/library/.gitkeep

# Local-only deploy target config (host/path) — never commit
/deploy/deploy.env

# Phase 2 rect-layout data — editor-authored (written by /dev/page/save),
# same rationale as the Deco JSON above: ignored so pulls never collide
# with locally-saved layouts. (Slice 1 intended these ignored; the rule
# was missing until the Slice 2 commit.)
/content/*/rects.json
/content/*/*/rects.json

# Image workshop = local stock of candidate images under test, not
# source. Ignore every batch (drafts + published) and keep only the
# container page record so /dev/image-workshop resolves on a fresh
# checkout.
/content/dev/image-workshop/*
!/content/dev/image-workshop/image-workshop.txt
