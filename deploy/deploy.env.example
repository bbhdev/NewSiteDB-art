# Copy to deploy/deploy.env (gitignored) and fill in your server.
# deploy.sh sources this file if present.

# SSH target. Best practice: define a Host alias in ~/.ssh/config with a
# key, then just use the alias here (no password prompts, no inline user):
#   Host bondard
#     HostName bondard.net
#     User youruser
#     IdentityFile ~/.ssh/id_ed25519
REMOTE_HOST="bondard"

# Absolute path to the web root on the server (the dir containing index.php).
REMOTE_PATH="/var/www/bondard.net"
