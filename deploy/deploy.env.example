# Copy to deploy/deploy.env (gitignored) and fill in your server.
# deploy.sh sources this file if present.

# SSH target. Best practice: define a Host alias in ~/.ssh/config with a
# key, then just use the alias here (no password prompts, no inline user).
# For this project (Infomaniak shared hosting):
#   Host newsitedbart
#     HostName 1m5eb.ftp.infomaniak.com
#     User 1m5eb_from_infomaniak
#     IdentityFile ~/.ssh/id_ed25519
REMOTE_HOST="newsitedbart"

# Absolute path to the web root on the server (the dir containing index.php).
# On Infomaniak shared hosting, sites live under
# /home/clients/<account-hash>/sites/<sitename>/ — the account hash is
# stable across the hosting plan. Discovered with: ssh newsitedbart pwd
REMOTE_PATH="/home/clients/94e3ce6271e3648b7b00d6c32be0a6e2/sites/newsitedbart.bbh.fr"
