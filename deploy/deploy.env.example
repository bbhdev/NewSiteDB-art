# Copy to deploy/deploy.env (gitignored) and fill in your targets.
# deploy.sh sources this file if present.
#
# Named-target model: each entry is keyed by the site's SERVER_NAME — the
# domain browsers hit. Using SERVER_NAME as the target name keeps three
# things in lockstep: (1) the CLI arg you type to deploy.sh, (2) the row
# picked here, (3) the host-scoped config filename
# site/config/config.<SERVER_NAME>.php (rsync-excluded; each server keeps
# its own copy).
#
# SSH best practice: define a Host alias in ~/.ssh/config with an
# IdentityFile and use the alias here (no password prompts, no inline
# user). Multiple targets that share one SSH account use the same
# REMOTE_HOST alias but different REMOTE_PATH subdirs. Example:
#   Host newsitedbart
#     HostName 1m5eb.ftp.infomaniak.com
#     User 1m5eb_from_infomaniak
#     IdentityFile ~/.ssh/id_ed25519
#
# Discover REMOTE_PATH on Infomaniak shared hosting with:
#   ssh <alias> 'ls -d ~/sites/*'

# Space-separated list of valid target names. Must match the case
# branches in resolve_target() below.
TARGETS="newsitedbart.bbh.fr danielbondard.fr"

# Target used when deploy.sh is invoked with no positional argument.
DEFAULT_TARGET="newsitedbart.bbh.fr"

# Resolve a target name → REMOTE_HOST + REMOTE_PATH. Add a branch per
# target. Return 1 on unknown name so deploy.sh can error cleanly.
resolve_target() {
  case "$1" in
    newsitedbart.bbh.fr)
      REMOTE_HOST="newsitedbart"
      REMOTE_PATH="/home/clients/94e3ce6271e3648b7b00d6c32be0a6e2/sites/newsitedbart.bbh.fr"
      ;;
    danielbondard.fr)
      REMOTE_HOST="newsitedbart"
      REMOTE_PATH="/home/clients/94e3ce6271e3648b7b00d6c32be0a6e2/sites/danielbondard.fr"
      ;;
    *)
      return 1
      ;;
  esac
}
